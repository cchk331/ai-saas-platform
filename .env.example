# =============================================================================
# AI SaaS Platform - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# Rationale: Centralizes all environment variables across the three products.
# Each variable is documented with its purpose and which product requires it.
# =============================================================================

# ---------------------------------------------------------------------------
# General
# ---------------------------------------------------------------------------
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ---------------------------------------------------------------------------
# Database (shared across all products)
# ---------------------------------------------------------------------------
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ai_saas
REDIS_URL=redis://localhost:6379

# ---------------------------------------------------------------------------
# Finance OS (Product 1 - Cash Ops)
# ---------------------------------------------------------------------------
# Plaid integration for bank account linking
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=sandbox

# ---------------------------------------------------------------------------
# Analytics Copilot (Product 2 - Text-to-SQL)
# ---------------------------------------------------------------------------
# OpenAI for natural language to SQL translation
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# Data warehouse connection for governed queries
WAREHOUSE_URL=postgresql://readonly:readonly@localhost:5432/warehouse

# ---------------------------------------------------------------------------
# Media Buyer (Product 3 - Ad Automation)
# ---------------------------------------------------------------------------
# Meta Ads API
META_APP_ID=
META_APP_SECRET=
META_ACCESS_TOKEN=

# Google Ads API
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_REFRESH_TOKEN=

# ---------------------------------------------------------------------------
# Observability & Feedback
# ---------------------------------------------------------------------------
POSTHOG_API_KEY=
SENTRY_DSN=
