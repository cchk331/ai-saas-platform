# Analytics Copilot API Environment Variables
# Rationale: Documents required env vars for the Text-to-SQL backend.
#
# Steps:
# 1. Copy: cp .env.example .env
# 2. Get OpenAI API key from https://platform.openai.com/api-keys
# 3. Set database connection for query execution

# OpenAI (for natural language to SQL translation)
OPENAI_API_KEY=sk-your_openai_api_key
OPENAI_MODEL=gpt-4-turbo

# Database for query execution
DATABASE_URL=postgresql://user:password@localhost:5432/analytics
DUCKDB_PATH=./data/analytics.duckdb

# API Configuration
API_HOST=0.0.0.0
API_PORT=8001
CORS_ORIGINS=http://localhost:3001

# Query caching (TTL in seconds)
CACHE_TTL=300

# Rate limiting
MAX_QUERIES_PER_MINUTE=30
