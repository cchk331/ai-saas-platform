# Finance OS API Environment Variables
# Rationale: Documents all required environment variables for the Finance OS
# backend. Copy this file to .env and fill in your actual values.
#
# Steps:
# 1. Copy: cp .env.example .env
# 2. Fill in Plaid credentials from https://dashboard.plaid.com
# 3. Set database URL for your PostgreSQL instance
# 4. Configure CORS origin to match your frontend URL

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/finance_os

# Plaid API (https://dashboard.plaid.com)
PLAID_CLIENT_ID=your_plaid_client_id
PLAID_SECRET=your_plaid_secret
PLAID_ENV=sandbox

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:3000

# JWT Secret for authentication
JWT_SECRET=change_me_to_a_random_string

# Optional: Redis for caching
REDIS_URL=redis://localhost:6379/0
