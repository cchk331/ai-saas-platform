# Media Buyer API Environment Variables
# Rationale: Documents required env vars for the Ad Automation backend.
#
# Steps:
# 1. Copy: cp .env.example .env
# 2. Get Meta/Google/TikTok ad platform credentials
# 3. Configure Redis for campaign metric caching

# Meta Ads API
META_APP_ID=your_meta_app_id
META_APP_SECRET=your_meta_app_secret
META_ACCESS_TOKEN=your_meta_access_token

# Google Ads API
GOOGLE_ADS_DEVELOPER_TOKEN=your_developer_token
GOOGLE_ADS_CLIENT_ID=your_client_id
GOOGLE_ADS_CLIENT_SECRET=your_client_secret
GOOGLE_ADS_REFRESH_TOKEN=your_refresh_token

# TikTok Marketing API
TIKTOK_ACCESS_TOKEN=your_tiktok_access_token
TIKTOK_APP_ID=your_tiktok_app_id

# API Configuration
API_HOST=0.0.0.0
API_PORT=8002
CORS_ORIGINS=http://localhost:3002

# Redis for caching
REDIS_URL=redis://localhost:6379/2

# Optimization scheduler interval (minutes)
OPTIMIZATION_INTERVAL=15
